{
  "name": "openenv",
  "version": "0.1.0",
  "description": "The open standard for production-ready full-stack starter kits",
  "type": "module",
  "bin": {
    "openenv": "./src/index.js"
  },
  "files": [
    "src",
    "registry.json",
    "README.md"
  ],
  "keywords": [
    "cli",
    "starter-kit",
    "boilerplate",
    "scaffold",
    "fullstack",
    "openenv"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "node src/index.js",
    "start": "node src/index.js",
    "prepublishOnly": "node --input-type=module -e \"import('./src/index.js').catch(() => {})\" || true"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "boxen": "^7.1.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fs-extra": "^11.2.0",
    "inquirer": "^9.3.7",
    "ora": "^8.1.0",
    "semver": "^7.6.3",
    "simple-git": "^3.25.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/openenv/openenv.git"
  },
  "homepage": "https://openenv.dev",
  "bugs": {
    "url": "https://github.com/openenv/openenv/issues"
  }
}
